[Unit]
Description=Danbyte monitoring retention (prune old check results)
After=network.target
Wants=danbyte-infra.service

[Service]
Type=oneshot
WorkingDirectory=%h/danbyte
Environment=PYTHONUNBUFFERED=1
ExecStart=%h/danbyte/.venv/bin/python manage.py prune_check_results
ExecStart=%h/danbyte/.venv/bin/python manage.py prune_changelog

# Triggered daily by danbyte-prune.timer.
# Logs: journalctl --user -fu danbyte-prune
