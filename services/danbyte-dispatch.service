[Unit]
Description=Danbyte monitoring dispatcher (enqueue due checks)
After=network.target
Wants=danbyte-infra.service

[Service]
Type=oneshot
WorkingDirectory=%h/danbyte
Environment=PYTHONUNBUFFERED=1
ExecStart=%h/danbyte/.venv/bin/python manage.py dispatch_checks

# Triggered every minute by danbyte-dispatch.timer.
# Logs: journalctl --user -fu danbyte-dispatch
