[Unit]
Description=Run the Danbyte config-drift dispatcher every minute

[Timer]
# Minute-resolution beat: the command self-throttles to the configured interval.
OnCalendar=*:0/1
# Run a catch-up tick on boot rather than waiting for the next minute boundary.
OnBootSec=30
Persistent=true
AccuracySec=1s

[Install]
WantedBy=timers.target
