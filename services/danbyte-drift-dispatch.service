[Unit]
Description=Danbyte scheduled config-drift dispatcher
After=network.target
Wants=danbyte-infra.service

[Service]
Type=oneshot
WorkingDirectory=%h/danbyte
Environment=PYTHONUNBUFFERED=1
ExecStart=%h/danbyte/.venv/bin/python manage.py drift_dispatch

# Triggered every minute by danbyte-drift-dispatch.timer (self-throttles to the
# configured interval).
# Logs: journalctl --user -fu danbyte-drift-dispatch
