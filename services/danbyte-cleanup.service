[Unit]
Description=Danbyte stale discovered-IP cleanup (opt-in)
After=network.target
Wants=danbyte-infra.service

[Service]
Type=oneshot
WorkingDirectory=%h/danbyte
Environment=PYTHONUNBUFFERED=1
ExecStart=%h/danbyte/.venv/bin/python manage.py cleanup_stale_ips

# Triggered daily by danbyte-cleanup.timer.
# Logs: journalctl --user -fu danbyte-cleanup
