[Unit]
Description=Danbyte scheduled email digests
After=network.target
Wants=danbyte-infra.service

[Service]
Type=oneshot
WorkingDirectory=%h/danbyte
Environment=PYTHONUNBUFFERED=1
ExecStart=%h/danbyte/.venv/bin/python manage.py send_digest

# Triggered daily by danbyte-digest.timer; each tenant is gated by its own
# effective frequency (daily / weekly weekday) and last-sent date.
# Logs: journalctl --user -fu danbyte-digest
