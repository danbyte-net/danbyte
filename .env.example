# Django
DJANGO_SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Is this deployment served over TLS? Turns on the app-level transport hardening
# (Secure session/CSRF cookies, HSTS, http->https redirect). Independent of DEBUG
# on purpose. Only enable it if you actually terminate TLS (the quick installer
# sets up nginx+TLS and writes DANBYTE_HTTPS=True for you) — enabling it on a
# plain-http server makes the browser DROP the session cookie, so login silently
# bounces back to the form with no error.
# DANBYTE_HTTPS=True

# Monitoring secrets-at-rest key. Encrypts SNMP/SSH/SMTP/LDAP credentials in the
# database independently of DJANGO_SECRET_KEY (so rotating the Django key doesn't
# void stored credentials, and a Django-key leak can't decrypt them). REQUIRED
# when DEBUG=False — the app refuses to start otherwise. Generate one with:
#   python -c 'import secrets; print(secrets.token_urlsafe(50))'
# In dev (DEBUG=True) it may be left unset; the key is then derived from
# DJANGO_SECRET_KEY. Do NOT change this once credentials are stored — the old
# ciphertext becomes undecryptable.
# MONITORING_SECRET_KEY=

# SSRF: on a cloud, multi-tenant deployment set this so the CENTRAL check runner
# refuses check targets that resolve to loopback / RFC1918 / reserved (a tenant
# could otherwise probe the server's own internal services). The cloud-metadata
# endpoint is always refused. Leave False for self-hosted LAN monitoring from the
# central box. DANBYTE_SSRF_ALLOWLIST exempts specific CIDRs.
# DANBYTE_CHECK_BLOCK_INTERNAL=False
# DANBYTE_SSRF_ALLOWLIST=192.168.0.0/24,10.1.2.3

# Logging — set to a writable dir (production: /var/log/danbyte) to mirror app
# logs to <dir>/danbyte.log + gunicorn logs there. Leave unset in dev; logs
# then go only to the console / journald.
# DANBYTE_LOG_DIR=/var/log/danbyte

# Database
DB_ENGINE=django.db.backends.postgresql
DB_NAME=danbyte
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@danbyte.com
