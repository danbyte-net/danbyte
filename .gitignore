# ── Python ───────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
eggs/
sdist/
develop-eggs/
downloads/
parts/
.installed.cfg
build/
wheels/
var/
# Anchored to the repo root: setuptools build artifacts (./lib, ./lib64).
# Un-anchored they also swallowed frontend/src/lib/ — the SPA's api types +
# hooks — which must be tracked. (.venv/lib is covered by .venv/.)
/lib/
/lib64/

# ── Virtualenv ───────────────────────────────────────────────────────────
.venv/
env/
ENV/
venv/

# ── Test / coverage ──────────────────────────────────────────────────────
.cache
.coverage
*.cover
coverage.xml
htmlcov/
nosetests.xml
.pytest_cache/

# ── Django / runtime ─────────────────────────────────────────────────────
db.sqlite3
db.sqlite3-journal
local_settings.py
media/
staticfiles/
*.log
# In-app upgrade runtime artifacts (see core/upgrade.py).
.upgrade-status.json
.upgrade.lock*
.upgrade-bundle.tar.gz

# ── Environment ──────────────────────────────────────────────────────────
.env
.env.local

# ── Node / frontend build ────────────────────────────────────────────────
node_modules/
dist/

# ── Zensical docs build output (regenerated by `zensical build`) ─────────
/site/

# ── IDE / OS ─────────────────────────────────────────────────────────────
.idea/
.vscode/
.DS_Store
*.swo
*.swp

# ── Local TLS certs/keys — generated by `make proxy-cert`, never commit ───
deploy/nginx/certs/

# ── Internal AI / planning / archived material — not shipped public ──────
notes/
# The whole .claude/ dir (Claude Code settings, hooks, internal setup/design/
# planning notes) stays on disk but out of the public repo.
.claude/
/reference/
/.agents/
/src/
# Dev-only demo seeders + Claude Code skills lockfile — kept locally, untracked.
/skills-lock.json
/scripts_seed_cable_demo.py
/scripts_seed_fiber_demo.py

# Uploaded (offline) plugins — runtime data, never committed
plugins_local/
